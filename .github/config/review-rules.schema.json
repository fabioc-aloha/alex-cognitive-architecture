{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alex Review Rules",
  "description": "Learned code review patterns for automated and AI-assisted review",
  "type": "object",
  "required": ["version", "rules"],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "severity", "pattern", "message"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Unique rule identifier"
          },
          "category": {
            "type": "string",
            "enum": ["security", "architecture", "documentation", "testing", "performance", "accessibility"],
            "description": "Rule category"
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"],
            "description": "Severity level"
          },
          "pattern": {
            "type": "string",
            "description": "Regex pattern to detect the issue"
          },
          "message": {
            "type": "string",
            "description": "Human-readable explanation and fix guidance"
          },
          "learnedFrom": {
            "type": "string",
            "description": "Source of this rule (instruction file, incident, etc.)"
          },
          "fileGlob": {
            "type": "string",
            "description": "Glob pattern for files this rule applies to"
          }
        }
      }
    }
  }
}
