{
  "$schema": "./token-budget.schema.json",
  "version": "1.0.0",
  "defaults": {
    "maxTokensPerSession": 100000,
    "maxTokensPerTask": 25000,
    "maxLoopIterations": 10,
    "loopGuard": {
      "enabled": true,
      "maxConsecutiveFailures": 3,
      "cooldownMinutes": 5,
      "maxRetries": 2
    }
  },
  "taskOverrides": {
    "dream-protocol": {
      "maxTokensPerTask": 50000,
      "maxLoopIterations": 15
    },
    "brain-audit": {
      "maxTokensPerTask": 40000,
      "maxLoopIterations": 5
    },
    "fleet-health": {
      "maxTokensPerTask": 30000,
      "maxLoopIterations": 8
    }
  },
  "alerts": {
    "budgetWarningThreshold": 0.8,
    "budgetCriticalThreshold": 0.95,
    "showInHealthPulse": true
  }
}
