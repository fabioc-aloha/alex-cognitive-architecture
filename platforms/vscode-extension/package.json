{
  "name": "alex-cognitive-architecture",
  "displayName": "Alex Cognitive Architecture",
  "description": "Your cognitive learning partner — AI-powered creative assistant with memory, reflection, and growth.",
  "version": "8.1.2",
  "publisher": "fabioc-aloha",
  "license": "PolyForm-Noncommercial-1.0.0",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/fabioc-aloha/alex-cognitive-architecture"
  },
  "homepage": "https://github.com/fabioc-aloha/alex-cognitive-architecture/wiki",
  "bugs": {
    "url": "https://github.com/fabioc-aloha/alex-cognitive-architecture/issues"
  },
  "markdown": "github",
  "qna": "https://github.com/fabioc-aloha/alex-cognitive-architecture/discussions",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Extension Packs",
    "Education"
  ],
  "keywords": [
    "ai",
    "copilot",
    "cognitive architecture",
    "brain",
    "skills",
    "instructions",
    "prompts"
  ],
  "extensionDependencies": [
    "GitHub.copilot-chat"
  ],
  "extensionPack": [
    "GitHub.copilot-chat",
    "ms-vscode.powershell",
    "redhat.vscode-yaml",
    "bierner.markdown-mermaid",
    "DavidAnson.vscode-markdownlint"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Alex Cognitive Architecture",
      "properties": {
        "alex.aiMemory.path": {
          "type": "string",
          "default": "",
          "description": "Custom path to the AI-Memory folder for cross-project knowledge sharing. Leave empty for auto-detection (OneDrive preferred)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "alex-sidebar",
          "title": "Alex",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "alex-sidebar": [
        {
          "type": "webview",
          "id": "alex.welcomeView",
          "name": "Welcome"
        },
        {
          "id": "alex.agentActivity",
          "name": "Agent Activity"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "alex.chat",
        "fullName": "Alex",
        "name": "alex",
        "description": "Your cognitive learning partner — ask anything, create anything, grow together.",
        "isSticky": true,
        "commands": [
          {
            "name": "autopilot",
            "description": "Manage scheduled Autopilot tasks — list, status, run"
          },
          {
            "name": "cloud",
            "description": "Dispatch Autopilot tasks to GitHub Actions for cloud execution"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "alex.openChat",
        "title": "Chat with Alex",
        "category": "Alex"
      },
      {
        "command": "alex.dream",
        "title": "Run Dream Protocol",
        "category": "Alex"
      },
      {
        "command": "alex.initialize",
        "title": "Initialize Workspace",
        "category": "Alex"
      },
      {
        "command": "alex.upgrade",
        "title": "Upgrade Architecture",
        "category": "Alex"
      },
      {
        "command": "alex.generateLoopConfig",
        "title": "Generate Loop Config",
        "category": "Alex"
      },
      {
        "command": "alex.setProjectPhase",
        "title": "Set Project Phase",
        "category": "Alex"
      },
      {
        "command": "alex.setupAIMemory",
        "title": "Setup AI-Memory",
        "category": "Alex"
      },
      {
        "command": "alex.refreshAgentActivity",
        "title": "Refresh Agent Activity",
        "category": "Alex",
        "icon": "$(refresh)"
      },
      {
        "command": "alex.refreshWelcome",
        "title": "Refresh Welcome",
        "category": "Alex",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "alex.refreshAgentActivity",
          "when": "view == alex.agentActivity",
          "group": "navigation"
        },
        {
          "command": "alex.refreshWelcome",
          "when": "view == alex.welcomeView",
          "group": "navigation"
        }
      ]
    },
