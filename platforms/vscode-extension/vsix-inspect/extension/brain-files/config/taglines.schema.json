{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project Taglines Configuration",
  "description": "Project-specific taglines for the Alex sidebar banner",
  "type": "object",
  "required": ["version", "project", "taglines"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "const": "1.0"
    },
    "project": {
      "type": "string",
      "description": "Project name for display purposes"
    },
    "taglines": {
      "type": "object",
      "description": "Tagline pools organized by category",
      "properties": {
        "project": {
          "type": "array",
          "description": "Taglines specific to this project's identity and purpose",
          "items": { "type": "string", "minLength": 5, "maxLength": 60 },
          "minItems": 3
        },
        "vision": {
          "type": "array",
          "description": "Taglines reflecting the project's North Star/goals",
          "items": { "type": "string", "minLength": 5, "maxLength": 60 }
        },
        "collaboration": {
          "type": "array",
          "description": "Taglines about human-AI partnership for this project",
          "items": { "type": "string", "minLength": 5, "maxLength": 60 }
        }
      },
      "required": ["project"],
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "rotation": {
      "type": "object",
      "description": "How to balance project vs inspirational taglines",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["balanced", "project-heavy", "inspirational-heavy"],
          "default": "balanced"
        },
        "projectWeight": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 50
        },
        "inspirationalWeight": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 50
        }
      }
    }
  }
}
