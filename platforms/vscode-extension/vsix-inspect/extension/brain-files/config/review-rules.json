{
  "$schema": "./review-rules.schema.json",
  "version": "1.0.0",
  "rules": [
    {
      "id": "sec-no-inline-handlers",
      "category": "security",
      "severity": "error",
      "pattern": "onclick=|onerror=|onload=",
      "message": "Use event delegation instead of inline handlers to prevent XSS",
      "learnedFrom": "learned-patterns.instructions.md",
      "fileGlob": "**/*.{ts,tsx,js,jsx,html}"
    },
    {
      "id": "sec-sanitize-boundaries",
      "category": "security",
      "severity": "error",
      "pattern": "stack|stackTrace|__dirname|__filename",
      "message": "Strip internal paths and stack traces from user-facing error messages",
      "learnedFrom": "learned-patterns.instructions.md",
      "fileGlob": "**/*.{ts,js}"
    },
    {
      "id": "sec-path-traversal",
      "category": "security",
      "severity": "error",
      "pattern": "\\.\\./|\\.\\.\\\\",
      "message": "Validate resolved paths stay within intended directory root",
      "learnedFrom": "learned-patterns.instructions.md",
      "fileGlob": "**/*.{ts,js,cjs,mjs}"
    },
    {
      "id": "doc-hardcoded-counts",
      "category": "documentation",
      "severity": "warning",
      "pattern": "\\b(\\d{2,3})\\s+(skills|instructions|prompts|agents|muscles)",
      "message": "Hardcoded counts drift — use dynamic reads or 'as of [date]' stamps",
      "learnedFrom": "learned-patterns.instructions.md",
      "fileGlob": "**/*.md"
    },
    {
      "id": "arch-no-extension-import",
      "category": "architecture",
      "severity": "error",
      "pattern": "from.*platforms/vscode-extension/\\.github|require.*platforms/vscode-extension/\\.github",
      "message": "Architecture must not import brain files from extension path (I8)",
      "learnedFrom": "copilot-instructions.md",
      "fileGlob": ".github/**/*.{ts,js,cjs,mjs}"
    },
    {
      "id": "quality-escattr-coverage",
      "category": "security",
      "severity": "warning",
      "pattern": "escAttr",
      "message": "escAttr must cover 6 chars: & < > \" ' ` — missing any creates injection vectors",
      "learnedFrom": "learned-patterns.instructions.md",
      "fileGlob": "**/*.{ts,js}"
    },
    {
      "id": "fleet-no-heir-source",
      "category": "architecture",
      "severity": "error",
      "pattern": "heir/\\.github/|heir\\\\\\.github\\\\",
      "message": "Canonical brain source is root .github/ — heir/.github/ is generated by sync-to-heir",
      "learnedFrom": "repo-memory",
      "fileGlob": "scripts/**/*.{ps1,cjs,mjs}"
    },
    {
      "id": "test-no-empty-assertion",
      "category": "testing",
      "severity": "warning",
      "pattern": "expect\\(\\)\\.|assert\\.ok\\(\\)",
      "message": "Empty assertions provide no value — assert specific behavior",
      "learnedFrom": "test-quality-analysis.instructions.md",
      "fileGlob": "**/*.test.*"
    }
  ]
}
